{
  "expo": {
    "name": "Flag That",
    "slug": "flagsareus",
    "scheme": "flagthat",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flagsareus.app",
      "buildNumber": "1",
      "associatedDomains": ["applinks:flagthat.app"],
      "minimumOSVersion": "16.0",
      "infoPlist": {
        "CFBundleDisplayName": "Flag That",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.flagsareus.app",
      "minSdkVersion": 24,
      "targetSdkVersion": 35,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "flagthat.app", "pathPrefix": "/c/" }],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "flagthat.app", "pathPrefix": "/r/" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F5EFE6",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Flag That",
      "shortName": "Flag That",
      "description": "Test your knowledge of 195+ country flags",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-screen-orientation",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
