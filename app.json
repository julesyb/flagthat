{
  "expo": {
    "name": "Flag That",
    "slug": "flagsareus",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9FAFB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flagsareus.app",
      "infoPlist": {
        "CFBundleDisplayName": "Flag That"
      }
    },
    "android": {
      "package": "com.flagsareus.app",
      "adaptiveIcon": {
        "backgroundColor": "#F9FAFB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "Flag That",
      "shortName": "Flag That",
      "description": "Test your knowledge of 195+ country flags",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-screen-orientation"
    ]
  }
}
